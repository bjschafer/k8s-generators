        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "tgWxX424k"
                      },
                      "group": "postgres",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "format": "table",
                        "key": "Q-6519d63b-8a73-471e-a7e2-1a0421b7c906-0",
                        "rawQuery": true,
                        "rawSql": "SELECT\n  spool.id AS spool_id,\n  color_hex,\n  material,\n  TRUNC((1 - spool.used_weight / filament.weight) * 100) AS percent,\n  spool.comment AS filament_comment,\n  filament.name AS filament_name,\n  vendor.name AS vendor_name\nFROM\n  filament\n  JOIN spool ON filament.id = spool.filament_id\n  JOIN vendor ON filament.vendor_id = vendor.id\nWHERE\n  NOT spool.archived --ORDER BY color_hex;\n  --AND material IN ($material)",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [
                                {
                                  "name": "id",
                                  "type": "functionParameter"
                                }
                              ],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        },
                        "table": "spool"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "",
          "id": 1,
          "links": [],
          "title": "Available colors",
          "vizConfig": {
            "group": "marcusolsson-dynamictext-panel",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      },
                      {
                        "color": "#EAB839",
                        "value": 40
                      },
                      {
                        "color": "red",
                        "value": 100
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "afterRender": "",
                "content": "\u003ctable\u003e\n  \u003ctr\u003e\n    \u003cth\u003eColor\u003c/th\u003e\n    \u003cth\u003eMaterial\u003c/th\u003e\n    \u003cth\u003eDescription\u003c/th\u003e\n    \u003cth\u003eNotes\u003c/th\u003e\n    \u003cth\u003eRemain\u0026nbsp;%\u003c/th\u003e\n    \u003cth class=\"extra\"\u003eID\u003c/th\u003e\n  \u003c/tr\u003e\n  {{#each data}}\n  \u003ctr\u003e\n    \u003ctd class=\"color\"\u003e\n      \u003cdiv title=\"#{{color_hex}}\" class=\"color\" style=\"background-color: #{{color_hex}};\"\u003e\u003c/div\u003e\n    \u003c/td\u003e\n    \u003ctd class=\"material\"\u003e\n      {{material}}\n    \u003c/td\u003e\n    \u003ctd class=\"description\"\u003e\n      {{vendor_name}} {{filament_name}}\n    \u003c/td\u003e\n    \u003ctd class=\"notes\"\u003e\n      \u003cp\u003e{{filament_comment}}\u003c/p\u003e\n    \u003c/td\u003e\n    \u003ctd class=\"percent\"\u003e\n      {{percent}}\n    \u003ctd class=\"extra\"\u003e\n      \u003ca target=\"_blank\" class=\"spoolman\"\n        href=\"https://spoolman.cmdcentral.xyz/spool/show/{{spool_id}}\"\u003e{{spool_id}}\u003c/a\u003e\n    \u003c/td\u003e\n  \u003c/tr\u003e\n  {{/each}}\n\u003c/table\u003e",
                "contentPartials": [],
                "defaultContent": "The query didn't return any results.",
                "editor": {
                  "format": "auto",
                  "height": 362,
                  "language": "html"
                },
                "editors": [
