                ],
                "externalScripts": [],
                "externalStyles": [],
                "helpers": "",
                "renderMode": "allRows",
                "styles": "div.color {\n  height: 2em;\n  width: 2em;\n}\n\ntable,\ntr,\ntd,\nth,\ntbody {\n  border: 0px !important;\n}\n\ntable {\n  width: 100%;\n}\n\ntd.color {\n  width: 10%;\n}\n\ntd.material {\n  width: 10%;\n}\n\ntd.description {\n  width: 55%;\n}\n\ntd.percent {\n  width: 8%;\n}\n\ntd.extra,\nth.extra {\n  width: 10%;\n  text-align: right;\n}\n\ntd.notes,\nth.notes {\n  width: 15%;\n}\n\na.spoolman:hover {\n  text-decoration: underline;\n  color: rgb(153, 153, 174);\n}",
                "wrap": true
              }
