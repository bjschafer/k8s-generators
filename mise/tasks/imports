#!/usr/bin/env bash
#MISE description="Import CRDs and k8s API types"

set -euo pipefail

VERSION=$(kubectl get node | tail -n1 | awk '{ print $NF }' | sed -e 's/+.*$//' -e 's/[0-9]$/0/' -e 's/^v//')

CRD_JSON=$(mktemp)
trap 'rm -f "$CRD_JSON"' EXIT
kubectl get crd -ojson >"$CRD_JSON"

# --no-save: cdk8s import otherwise persists the SPEC argument verbatim into
# cdk8s.yaml's `imports:` list on every run, and never de-dupes/prunes it —
# that's how it accumulated stale k8s@ versions and literal /dev/fd paths
# from process substitution. We always pass explicit specs here, so there's
# nothing worth remembering between runs.
cdk8s import "k8s@$VERSION" --no-save
cdk8s import "$CRD_JSON" --no-save
